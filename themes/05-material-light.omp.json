{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 3,
  "final_space": true,
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "shell",
          "style": "diamond",
          "background": "#1976d2",
          "foreground": "#ffffff",
          "leading_diamond": "о‚¶",
          "template": " п„  {{ .Name }} "
        },
        {
          "type": "path",
          "style": "powerline",
          "powerline_symbol": "о‚°",
          "background": "#42a5f5",
          "foreground": "#ffffff",
          "properties": { "style": "agnoster_short", "max_depth": 3, "home_icon": "пЂ•" },
          "template": " пЃј {{ .Path }} "
        },
        {
          "type": "git",
          "style": "powerline",
          "powerline_symbol": "о‚°",
          "background": "#66bb6a",
          "background_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#ffa726{{ end }}",
            "{{ if gt .Ahead 0 }}#ab47bc{{ end }}",
            "{{ if gt .Behind 0 }}#ef5350{{ end }}"
          ],
          "foreground": "#ffffff",
          "template": " п„¦ {{ .HEAD }}{{ if .Working.Changed }} пЃ„ {{ .Working.String }}{{ end }} ",
          "properties": { "fetch_status": true }
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "right",
      "segments": [
        {
          "type": "command",
          "style": "diamond",
          "background": "#ffb300",
          "foreground": "#000000",
          "leading_diamond": "о‚¶",
          "trailing_diamond": "о‚ґ",
          "template": " {{ .Output }} ",
          "properties": {
            "shell": "pwsh",
            "command": "try { $w = (Invoke-RestMethod -TimeoutSec 1 'wttr.in/?format=%c%t' -ErrorAction Stop); $w } catch { '' }",
            "interval": 3600
          }
        },
        {
          "type": "time",
          "style": "diamond",
          "background": "#1976d2",
          "foreground": "#ffffff",
          "leading_diamond": " о‚¶",
          "trailing_diamond": "о‚ґ",
          "template": " пЃі {{ .CurrentDate | date \"Mon Jan 2 В· 15:04\" }} "
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "status",
          "style": "plain",
          "foreground": "#1976d2",
          "foreground_templates": ["{{ if gt .Code 0 }}#ef5350{{ end }}"],
          "template": "вќЇ ",
          "properties": { "always_enabled": true }
        }
      ]
    }
  ]
}
