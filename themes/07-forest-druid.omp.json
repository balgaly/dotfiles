        {
          "type": "text",
          "style": "diamond",
          "background": "#3d5a3a",
          "foreground": "#d4e09b",
          "leading_diamond": "ţéÂ",
          "template": " ţłť "
        },
        {
          "type": "path",
          "style": "powerline",
          "powerline_symbol": "ţé░",
          "background": "#5d8a4f",
