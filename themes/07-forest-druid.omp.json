            "command": "$d=(Get-Date); $age=($d - (Get-Date '2000-01-06')).TotalDays % 29.530588853; $i=[Math]::Floor($age / 29.530588853 * 8); $m=@('´âź','´âŚ','´ćć','´âŚ','´ćć','´âś','´ćć','´âś'); $m[$i]",
            "interval": 86400
          }
        },
        {
