{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 3,
  "final_space": true,
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "text",
          "style": "diamond",
          "background": "#ff00ff",
          "foreground": "#000000",
          "leading_diamond": "",
          "template": " ◆ SYNTH "
        },
        {
          "type": "path",
          "style": "powerline",
          "powerline_symbol": "",
          "background": "#7700ff",
          "foreground": "#00ffff",
          "properties": { "style": "agnoster_short", "max_depth": 2 },
          "template": "  {{ .Path }} "
        },
        {
          "type": "git",
          "style": "powerline",
          "powerline_symbol": "",
          "background": "#00ffff",
          "background_templates": ["{{ if or (.Working.Changed) (.Staging.Changed) }}#ff00aa{{ end }}"],
          "foreground": "#000000",
          "template": "  {{ .HEAD }}{{ if or (.Working.Changed) (.Staging.Changed) }} {{ end }} ",
          "properties": { "fetch_status": true }
        },
        {
          "type": "executiontime",
          "style": "diamond",
          "background": "#ff00aa",
          "foreground": "#ffffff",
          "trailing_diamond": "",
          "template": " {{ .FormattedMs }} ",
          "properties": { "threshold": 1, "style": "round" }
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "right",
      "segments": [
        {
          "type": "time",
          "style": "diamond",
          "background": "#ff00ff",
          "foreground": "#00ffff",
          "leading_diamond": "",
          "trailing_diamond": "",
          "template": "  {{ .CurrentDate | date \"15:04:05\" }} "
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "status",
          "style": "plain",
          "foreground": "#00ffff",
          "foreground_templates": ["{{ if gt .Code 0 }}#ff00aa{{ end }}"],
          "template": "▶▶▶ ",
          "properties": { "always_enabled": true }
        }
      ]
    }
  ]
}
